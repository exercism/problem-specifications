{
  "exercise": "hangman",
  "comments": [
    "The expected values may be returned from the guess function, or returned from a separate game state call.",
    "They may also be accessed from a different call for each value, based on what is most idiomatic for the language.",
    "To explore objects, each guessed letter should be a separate call."
  ],
  "cases": [
    {
      "uuid": "2419ffe6-16d8-4059-856a-9a101998a418",
      "description": "Initially 9 failures are allowed and no letters are guessed",
      "property": "guess",
      "input": {
        "word": "loot",
        "guesses": []
      },
      "expected": {
        "state": "Ongoing",
        "maskedWord": "____",
        "remainingFailures": 9
      }
    },
    {
      "uuid": "17c4296d-daab-44dc-8155-37c77caa52c1",
      "description": "After 10 failures the game is over",
      "property": "guess",
      "input": {
        "word": "loot",
        "guesses": ["a", "b", "c", "d", "e", "f", "g", "h", "i", "j"]
      },
      "expected": {
        "state": "Lose",
        "maskedWord": "____",
        "remainingFailures": 0
      }
    },
    {
      "uuid": "77c9ae1f-bbc4-4ed4-b67e-08110cbcfc17",
      "description": "Losing with several correct guesses",
      "property": "guess",
      "input": {
        "word": "loot",
        "guesses": ["t", "o", "a", "b", "c", "d", "e", "f", "g", "h", "i", "j"]
      },
      "expected": {
        "state": "Lose",
        "maskedWord": "_oot",
        "remainingFailures": 0
      }
    },
    {
      "uuid": "25101d8d-9874-405b-9825-193a14b69753",
      "description": "Feeding a correct letter removes underscores",
      "property": "guess",
      "input": {
        "word": "loot",
        "guesses": ["t"]
      },
      "expected": {
        "state": "Ongoing",
        "maskedWord": "___t",
        "remainingFailures": 9
      }
    },
    {
      "uuid": "8e6bd521-bc9b-458f-9cce-f57f4140c173",
      "description": "Feeding a correct letter twice counts as a failure",
      "property": "guess",
      "input": {
        "word": "loot",
        "guesses": ["t", "t"]
      },
      "expected": {
        "state": "Ongoing",
        "maskedWord": "___t",
        "remainingFailures": 8
      }
    },
    {
      "uuid": "5e6971b7-5e5f-49c2-b85d-1dd6aeb53bd5",
      "description": "Guessing a repeated letter reveals all instances",
      "property": "guess",
      "input": {
        "word": "loot",
        "guesses": ["t", "t", "o"]
      },
      "expected": {
        "state": "Ongoing",
        "maskedWord": "_oot",
        "remainingFailures": 8
      }
    },
    {
      "uuid": "a6c69d92-01ef-4b81-b9d9-801131e79bbb",
      "description": "Getting all the letters right makes for a win",
      "property": "guess",
      "input": {
        "word": "loot",
        "guesses": ["t", "t", "o", "l"]
      },
      "expected": {
        "state": "Win",
        "maskedWord": "loot",
        "remainingFailures": 8
      }
    },
    {
      "uuid": "2dc47994-b434-4a26-b70c-1eebeff77fe4",
      "description": "Winning on the last guess is still a win",
      "property": "guess",
      "input": {
        "word": "loot",
        "guesses": ["a", "b", "c", "d", "e", "f", "g", "h", "i", "t", "o", "l"]
      },
      "expected": {
        "state": "Win",
        "maskedWord": "loot",
        "remainingFailures": 0
      }
    },
    {
      "uuid": "52801d56-6963-494b-a901-5736e46ddc12",
      "description": "Guessing after a lose is error",
      "property": "guess",
      "input": {
        "word": "loot",
        "guesses": ["a", "b", "c", "d", "e", "f", "g", "h", "i", "j", "k"]
      },
      "expected": {
        "error": "cannot guess after the game is lost"
      }
    },
    {
      "uuid": "29a874f3-a413-4e1b-9a60-6be018e70b60",
      "description": "Guessing after a win is error",
      "property": "guess",
      "input": {
        "word": "loot",
        "guesses": ["t", "o", "l", "l"]
      },
      "expected": {
        "error": "cannot guess after the game is won"
      }
    }
  ]
}
